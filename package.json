{
  "name": "awslabs-lisa",
  "version": "6.5.0",
  "description": "A scalable infrastructure-as-code solution for self-hosting and orchestrating LLM inference with RAG capabilities, providing low-latency access to generative AI and embedding models across multiple providers.",
  "keywords": [
    "aws",
    "bedrock",
    "chatbot",
    "generative-ai",
    "langchain",
    "litellm",
    "llm",
    "large-language-model",
    "openai",
    "rag",
    "retrieval-augmented-generation"
  ],
  "homepage": "https://awslabs.github.io/LISA/",
  "bugs": {
    "url": "https://github.com/awslabs/lisa/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awslabs/lisa.git"
  },
  "license": "Apache-2.0",
  "author": "Amazon Web Services (https://aws.amazon.com)",
  "type": "commonjs",
  "main": "jest.config.js",
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "files": [
    "VERSION",
    "bin",
    "lib",
    "lisa-sdk",
    "lambda",
    "scripts",
    "ecs_model_deployer",
    "vector_store_deployer",
    "dist"
  ],
  "workspaces": [
    "lib/user-interface/react",
    "lib/docs",
    "ecs_model_deployer",
    "vector_store_deployer",
    "mcp_server_deployer",
    "lib/core/layers/cdk",
    "cypress"
  ],
  "scripts": {
    "build": "tsc && npm run build --workspaces && if [ \"$BUILD_ASSETS\" = \"true\" ]; then npm run build:assets; fi",
    "build:archive": "BUILD_ASSETS=true npm run build",
    "build:assets": "./bin/build-assets",
    "deploy": "node scripts/deploy.mjs",
    "destroy": "node scripts/destroy.mjs",
    "bootstrap": "node scripts/bootstrap.mjs",
    "cdk:list": "npx cdk list",
    "setup": "npm run install:python && npm install",
    "install:python": "python3 -m pip install --upgrade pip && pip install --prefer-binary -r requirements-dev.txt && pip install -e lisa-sdk && pip install -e lib/serve/mcp-workbench",
    "install:ts": "npm install",
    "docker:login": "node scripts/docker-login.mjs",
    "model:check": "node scripts/model-check.mjs",
    "copy-dist": "cp VERSION ./dist/",
    "clean": "npm run clean --workspaces 2>/dev/null; rm -rf dist node_modules cdk.out build lib/rag/layer/TIKTOKEN_CACHE lib/serve/rest-api/TIKTOKEN_CACHE; find . -type f -name '*.pyc' -delete; find . -type d -name '__pycache__' -exec rm -rf {} + 2>/dev/null; find . -type d -name '.pytest_cache' -exec rm -rf {} + 2>/dev/null; find . -type d -name '*.egg-info' -exec rm -rf {} + 2>/dev/null; find . -type d -name '.mypy_cache' -exec rm -rf {} + 2>/dev/null; find . -type d -name '.tox' -exec rm -rf {} + 2>/dev/null; rm -f .hf_token_cache; true",
    "watch": "tsc -w",
    "test": "jest && npm run test --workspaces",
    "test:coverage": "jest --coverage && npm run test:coverage --workspaces --if-present && npm run test:python:coverage",
    "test:python:coverage": "pytest test/lambda test/mcp-workbench test/sdk test/rest-api --verbose --cov=lambda --cov=lib/serve/mcp-workbench/src --cov=lisa-sdk/lisapy --cov=lib/serve/rest-api/src --cov-report=term-missing --cov-fail-under=80 --cov-config=lib/serve/rest-api/.coveragerc",
    "test:lambda": "pytest test/lambda --verbose",
    "test:mcp-workbench": "pytest test/mcp-workbench --verbose",
    "test:sdk": "pytest test/sdk --verbose",
    "test:rest-api": "pytest test/rest-api --verbose",
    "test:integ": "node scripts/run-integration-tests.mjs run",
    "test:integ:setup": "node scripts/run-integration-tests.mjs setup",
    "test:integ:run": "node scripts/run-integration-tests.mjs run",
    "test:integ:all": "node scripts/run-integration-tests.mjs all",
    "test:integ:teardown": "node scripts/run-integration-tests.mjs teardown",
    "test:rag-integ": "pytest test/integration --verbose",
    "test:sdk-integ": "pytest test/integration/sdk --verbose",
    "test:metadata-integ": "pytest test/integration/test_repository_update_metadata_preservation.py --verbose",
    "test:update-baselines": "jest --testPathPatterns=snapshot.test.ts -- --updateBaselines",
    "cdk": "cdk",
    "prepare": "husky || true",
    "postinstall": "patch-package && (cd lib/user-interface/react && npx patch-package)",
    "dev": "cd lib/user-interface/react/ && npm run dev",
    "prepublishOnly": "BUILD_ASSETS=true npm run build && npm run copy-dist --workspaces",
    "migrate-properties": "node ./scripts/migrate-properties.mjs",
    "generateSchemaDocs": "npx zod2md -c ./lib/zod2md.config.ts && npx zod2md -c ./lib/zod2md.rag.ts",
    "generate-config": "tsx scripts/generate-config.ts",
    "generate-baseline": "node scripts/generate-baseline.mjs",
    "build:copy-deps": "node scripts/copy-deps.mjs"
  },
  "devDependencies": {
    "@aws-cdk/aws-lambda-python-alpha": "^2.243.0-alpha.0",
    "@aws-sdk/client-iam": "^3.1009.0",
    "@aws-sdk/client-ssm": "^3.1009.0",
    "@cdklabs/cdk-enterprise-iac": "^0.1.0",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/linkify-it": "^5.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.5.0",
    "@types/readline-sync": "^1.4.8",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "aws-cdk": "^2.1111.0",
    "depcheck": "^1.4.7",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lightningcss": "^1.32.0",
    "lint-staged": "^16.3.3",
    "readline-sync": "^1.4.10",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "wait-on": "^9.0.4",
    "zod2md": "^0.3.3"
  },
  "dependencies": {
    "@aws-sdk/util-dynamodb": "^3.996.2",
    "aws-cdk-lib": "^2.243.0",
    "cdk-ecr-deployment": "^4.1.2",
    "cdk-nag": "^2.37.55",
    "constructs": "^10.5.1",
    "js-yaml": "^4.1.1",
    "lodash": "^4.17.23",
    "source-map-support": "^0.5.21",
    "util": "^0.12.5",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.59.0",
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.1"
  },
  "peerDependencies": {
    "@cfworker/json-schema": "^4.1.0",
    "@types/lodash": "^4.17.14",
    "micromark": "4.0.0",
    "micromark-core-commonmark": "2.0.1"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "@eslint/js": "10.0.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node",
    "experimentalSpecifiers": true
  }
}
